<!DOCTYPE html>
<html lang="ko">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AIR: From Store Data to Retail Intelligence</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&display=swap"
    rel="stylesheet" />
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Noto Sans KR', sans-serif;
      background: #06101f;
      color: #e2e8f0;
      scroll-behavior: smooth;
    }

    .gradient-text {
      background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 50%, #34d399 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .gradient-text-warm {
      background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-bg {
      background: radial-gradient(ellipse 60% 80% at 15% 50%, rgba(59, 130, 246, 0.12) 0%, transparent 70%), radial-gradient(ellipse 60% 80% at 85% 50%, rgba(139, 92, 246, 0.12) 0%, transparent 70%), #06101f;
    }

    .section-alt {
      background: #0a1628;
    }

    .section-base {
      background: #06101f;
    }

    .glass {
      background: rgba(13, 27, 53, 0.8);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(59, 130, 246, 0.18);
      border-radius: 16px;
    }

    .glass-amber {
      background: rgba(20, 14, 4, 0.8);
      border: 1px solid rgba(245, 158, 11, 0.25);
      border-radius: 16px;
    }

    .glass-green {
      background: rgba(5, 20, 15, 0.8);
      border: 1px solid rgba(52, 211, 153, 0.25);
      border-radius: 16px;
    }

    .glass-red {
      background: rgba(20, 5, 5, 0.8);
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-radius: 16px;
    }

    .glow-blue {
      box-shadow: 0 0 40px rgba(59, 130, 246, 0.25);
    }

    .glow-purple {
      box-shadow: 0 0 40px rgba(139, 92, 246, 0.25);
    }

    .conn-line {
      stroke-dasharray: 8 4;
      animation: flowAnim 2s linear infinite;
    }

    .conn-line-slow {
      stroke-dasharray: 8 4;
      animation: flowAnim 3s linear infinite;
    }

    @keyframes flowAnim {
      to {
        stroke-dashoffset: -24;
      }
    }

    .fade-in {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes floatUp {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-7px);
      }
    }

    .float-1 {
      animation: floatUp 4.0s ease-in-out infinite;
    }

    .float-2 {
      animation: floatUp 4.5s ease-in-out infinite 0.3s;
    }

    .float-3 {
      animation: floatUp 3.8s ease-in-out infinite 0.7s;
    }

    .float-4 {
      animation: floatUp 4.2s ease-in-out infinite 1.1s;
    }

    .float-5 {
      animation: floatUp 3.6s ease-in-out infinite 1.5s;
    }

    .float-6 {
      animation: floatUp 3.2s ease-in-out infinite 1.9s;
    }

    @keyframes pulseDot {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(1.4);
      }
    }

    .pulse-dot {
      animation: pulseDot 2s ease-in-out infinite;
    }

    .badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 999px;
      letter-spacing: 0.03em;
    }

    .badge-blue {
      background: rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .badge-purple {
      background: rgba(139, 92, 246, 0.2);
      color: #c4b5fd;
      border: 1px solid rgba(139, 92, 246, 0.3);
    }

    .badge-green {
      background: rgba(52, 211, 153, 0.15);
      color: #6ee7b7;
      border: 1px solid rgba(52, 211, 153, 0.3);
    }

    .badge-amber {
      background: rgba(245, 158, 11, 0.15);
      color: #fcd34d;
      border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .badge-red {
      background: rgba(239, 68, 68, 0.15);
      color: #fca5a5;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    nav {
      background: rgba(6, 16, 31, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(59, 130, 246, 0.1);
    }

    .nav-link {
      color: #94a3b8;
      font-size: 13px;
      padding: 6px 14px;
      border-radius: 8px;
      transition: all 0.2s;
      cursor: pointer;
    }

    .nav-link:hover {
      color: #e2e8f0;
      background: rgba(59, 130, 246, 0.1);
    }

    .scenario-flow {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: center;
      gap: 8px;
    }

    .scenario-arrow {
      color: #475569;
      font-size: 20px;
      text-align: center;
    }

    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: #06101f;
    }

    ::-webkit-scrollbar-thumb {
      background: #3b82f6;
      border-radius: 3px;
    }

    /* Persona highlight */
    .query-bubble {
      background: rgba(13, 27, 53, 0.9);
      border: 1px solid rgba(59, 130, 246, 0.3);
      border-radius: 14px 14px 14px 14px;
      padding: 14px 18px;
      font-size: 15px;
      font-style: italic;
      color: #bfdbfe;
    }

    .answer-bubble {
      background: rgba(5, 20, 40, 0.9);
      border: 1px solid rgba(52, 211, 153, 0.3);
      border-radius: 14px 14px 14px 14px;
      padding: 14px 18px;
      font-size: 14px;
      color: #a7f3d0;
    }

    /* Tabs */
    .tab-btn {
      border: 1px solid rgba(59, 130, 246, 0.2);
      border-radius: 10px;
      padding: 10px 20px;
      color: #94a3b8;
      cursor: pointer;
      transition: all 0.2s;
      background: rgba(13, 27, 53, 0.5);
      font-size: 14px;
      white-space: nowrap;
    }

    .tab-btn:hover {
      border-color: rgba(59, 130, 246, 0.5);
      color: #bfdbfe;
    }

    .tab-btn.active {
      background: rgba(59, 130, 246, 0.15);
      border-color: rgba(59, 130, 246, 0.6);
      color: #93c5fd;
      font-weight: 600;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }


    /* ── 텍스트 사이즈 업 (가독성 강화) ── */
    html {
      font-size: 19px;
    }

    .badge {
      font-size: 13px;
      padding: 5px 14px;
    }

    .nav-link {
      font-size: 15px;
    }

    .query-bubble {
      font-size: 18px;
      padding: 16px 20px;
    }

    .answer-bubble {
      font-size: 17px;
      padding: 16px 20px;
    }

    .tab-btn {
      font-size: 16px;
      padding: 12px 24px;
    }

    .scenario-arrow {
      font-size: 28px;
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="text-sm font-semibold text-slate-200">SOLUM · AI for Retail</span>
      <div class="hidden md:flex items-center gap-1">
        <a class="nav-link" onclick="scrollToSection('desire')">Desire</a>
        <a class="nav-link" onclick="scrollToSection('gap')">Gap</a>
        <a class="nav-link" onclick="scrollToSection('solution')">Solution</a>
        <a class="nav-link" onclick="scrollToSection('ontology')">Ontology</a>
        <a class="nav-link" onclick="scrollToSection('outcome')">Outcome</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════ SLIDE 1 · OPENING ═══════════════════ -->
  <section
    class="hero-bg min-h-screen flex flex-col items-center justify-center text-center px-6 pt-14 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5"
      style="background-image: linear-gradient(rgba(59,130,246,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.5) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
    <div class="relative z-10 max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full border border-blue-500/30 bg-blue-500/10">
        <span class="w-2 h-2 rounded-full bg-green-400 pulse-dot"></span>
        <span class="text-sm text-blue-300 font-medium">AI for Retail</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black mb-6 leading-tight">
        <span class="gradient-text">AIR</span>:<br />From Store Data to<br />Retail Intelligence
      </h1>
      <p class="text-xl md:text-2xl text-slate-400 font-light mb-12 leading-relaxed italic">
        "Every store already has data.<br /><strong class="text-white font-semibold not-italic">AIR makes it
          think.</strong>"
      </p>
      <!-- SVG: disconnected but ready-to-connect nodes -->
      <div class="relative mx-auto" style="width:380px; height:220px;">
        <svg width="380" height="220" viewBox="0 0 380 220">
          <line x1="190" y1="95" x2="80" y2="55" stroke="#3b82f6" stroke-width="1.5" class="conn-line" opacity="0.3" />
          <line x1="190" y1="95" x2="300" y2="55" stroke="#8b5cf6" stroke-width="1.5" class="conn-line" opacity="0.3" />
          <line x1="190" y1="95" x2="50" y2="155" stroke="#34d399" stroke-width="1.5" class="conn-line-slow"
            opacity="0.3" />
          <line x1="190" y1="95" x2="330" y2="155" stroke="#f59e0b" stroke-width="1.5" class="conn-line-slow"
            opacity="0.3" />
          <line x1="190" y1="95" x2="190" y2="185" stroke="#a78bfa" stroke-width="1.5" class="conn-line"
            opacity="0.3" />
          <circle cx="190" cy="95" r="32" fill="rgba(59,130,246,0.15)" stroke="#3b82f6" stroke-width="2" />
          <text x="190" y="100" text-anchor="middle" fill="#93c5fd" font-size="13" font-weight="900">AIR</text>
          <circle cx="80" cy="50" r="22" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1.5" />
          <text x="80" y="54" text-anchor="middle" fill="#6ee7b7" font-size="9">Shelf</text>
          <circle cx="300" cy="50" r="22" fill="rgba(139,92,246,0.1)" stroke="#8b5cf6" stroke-width="1.5" />
          <text x="300" y="54" text-anchor="middle" fill="#c4b5fd" font-size="9">Camera</text>
          <circle cx="50" cy="160" r="22" fill="rgba(245,158,11,0.1)" stroke="#f59e0b" stroke-width="1.5" />
          <text x="50" y="164" text-anchor="middle" fill="#fcd34d" font-size="9">EPD</text>
          <circle cx="330" cy="160" r="22" fill="rgba(239,68,68,0.1)" stroke="#ef4444" stroke-width="1.5" />
          <text x="330" y="164" text-anchor="middle" fill="#fca5a5" font-size="9">Sales</text>
          <circle cx="190" cy="190" r="22" fill="rgba(59,130,246,0.1)" stroke="#60a5fa" stroke-width="1.5" />
          <text x="190" y="194" text-anchor="middle" fill="#bfdbfe" font-size="9">Inventory</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ SLIDE 2 · WHAT RETAILERS WANT ═══════════════════ -->
  <section id="desire" class="section-alt py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <span class="badge badge-blue mb-4">Step 1 · Desire</span>
        <h2 class="text-4xl font-black mb-4">What Retailers <span class="gradient-text">Actually Want</span></h2>
        <p class="text-slate-400 max-w-2xl mx-auto">무엇이 일어나는지 제때 파악하고, 왜 그런지 판단하고, 즉시 행동할 수 있는 매장</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-10 fade-in">
        <!-- Availability -->
        <div class="glass p-6 rounded-2xl" style="border-color: rgba(59,130,246,0.35);">
          <div class="flex items-center gap-3 mb-4">
            <!-- <div class="text-3xl">👁️</div> -->
            <div>
              <div class="text-base font-bold text-blue-300">Availability</div>
              <div class="text-xs text-slate-500">See</div>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div><span class="text-xs text-slate-500">풀어야 할 문제</span><br /><span class="text-slate-300">선반 상태를 <strong
                  class="text-white">제때 모른다</strong></span></div>
            <div><span class="text-xs text-slate-500">Retail Intelligence가 만드는 가치</span><br /><span
                class="text-blue-300 font-semibold">실시간 가시성</span></div>
            <div class="pt-2 border-t border-slate-700/50">
              <span class="text-xs text-slate-500">KPI</span><br />
              <span class="badge badge-blue">OOS Rate</span> <span class="badge badge-blue">Detection Time</span>
            </div>
          </div>
        </div>
        <!-- Operations -->
        <div class="glass p-6 rounded-2xl" style="border-color: rgba(139,92,246,0.35);">
          <div class="flex items-center gap-3 mb-4">
            <!-- <div class="text-3xl">🧠</div> -->
            <div>
              <div class="text-base font-bold text-purple-300">Operations</div>
              <div class="text-xs text-slate-500">Understand</div>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div><span class="text-xs text-slate-500">풀어야 할 문제</span><br /><span class="text-slate-300">왜 문제가 생겼는지
                <strong class="text-white">파악이 안 된다</strong></span></div>
            <div><span class="text-xs text-slate-500">Retail Intelligence가 만드는 가치</span><br /><span
                class="text-purple-300 font-semibold">맥락 기반 이해</span></div>
            <div class="pt-2 border-t border-slate-700/50">
              <span class="text-xs text-slate-500">KPI</span><br />
              <span class="badge badge-purple">Monitoring Coverage</span>
            </div>
          </div>
        </div>
        <!-- Execution -->
        <div class="glass p-6 rounded-2xl" style="border-color: rgba(52,211,153,0.35);">
          <div class="flex items-center gap-3 mb-4">
            <!-- <div class="text-3xl">⚡</div> -->
            <div>
              <div class="text-base font-bold text-green-300">Execution</div>
              <div class="text-xs text-slate-500">Act</div>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div><span class="text-xs text-slate-500">풀어야 할 문제</span><br /><span class="text-slate-300">알아도 <strong
                  class="text-white">즉시 대응할 수 없다</strong></span></div>
            <div><span class="text-xs text-slate-500">Retail Intelligence가 만드는 가치</span><br /><span
                class="text-green-300 font-semibold">즉시 실행 가능한 판단</span></div>
            <div class="pt-2 border-t border-slate-700/50">
              <span class="text-xs text-slate-500">KPI</span><br />
              <span class="badge badge-green">Response Time</span> <span class="badge badge-green">Conversion
                Loss</span>
            </div>
          </div>
        </div>
      </div>

      <div class="glass p-6 rounded-2xl text-center fade-in glow-blue">
        <p class="text-lg text-white font-semibold italic mb-3">"모든 매장 데이터가 하나의 의사결정 기준으로 연결되는 것<br />그것이 리테일러가 원하는
          Retail Intelligence입니다."</p>
        <p class="text-sm text-slate-500">하지만 현재 구조로는 이것이 불가능합니다.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ SLIDE 3 · WHY CONNECTED DATA ═══════════════════ -->
  <section id="gap" class="section-base py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <span class="badge badge-amber mb-4">Step 2 · Gap</span>
        <h2 class="text-4xl font-black mb-4">From Storing Data to<br /><span class="gradient-text-warm">Understanding
            Relationships</span></h2>
        <p class="text-slate-400 max-w-2xl mx-auto">현재 구조에서는 개별 조회는 가능하지만, <strong class="text-slate-200">맥락 기반 판단은
            불가능</strong>합니다.</p>
      </div>

      <!-- Silo vs Connected -->
      <div class="grid md:grid-cols-2 gap-8 mb-10 fade-in">
        <!-- LEFT: Current state - silos -->
        <div>
          <div class="text-center mb-4"><span class="badge badge-red">현재 구조</span></div>
          <div class="grid grid-cols-3 gap-3">
            <div class="float-1 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">🖥️</div>
              <div class="text-xs font-semibold text-red-300">ESL</div>
            </div>
            <div class="float-2 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">📷</div>
              <div class="text-xs font-semibold text-red-300">Camera</div>
            </div>
            <div class="float-3 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">📺</div>
              <div class="text-xs font-semibold text-red-300">Signage</div>
            </div>
            <div class="float-4 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">🗄️</div>
              <div class="text-xs font-semibold text-red-300">선반</div>
            </div>
            <div class="float-5 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">📡</div>
              <div class="text-xs font-semibold text-red-300">Sensor</div>
            </div>
            <div class="float-6 glass-red p-3 text-center rounded-2xl">
              <div class="text-2xl mb-1">+⍺</div>
              <div class="text-xs font-semibold text-red-300">Third Party</div>
            </div>
          </div>
        </div>
        <!-- RIGHT: Connected structure -->
        <div>
          <div class="text-center mb-4"><span class="badge badge-green">필요한 구조</span></div>
          <div class="glass-green p-6 rounded-2xl flex items-center justify-center" style="min-height: 180px;">
            <svg width="240" height="160" viewBox="0 0 240 160">
              <line x1="120" y1="50" x2="40" y2="30" stroke="#34d399" stroke-width="1.5" class="conn-line" />
              <line x1="120" y1="50" x2="200" y2="30" stroke="#34d399" stroke-width="1.5" class="conn-line" />
              <line x1="120" y1="50" x2="40" y2="120" stroke="#34d399" stroke-width="1.5" class="conn-line-slow" />
              <line x1="120" y1="50" x2="200" y2="120" stroke="#34d399" stroke-width="1.5" class="conn-line-slow" />
              <line x1="120" y1="50" x2="120" y2="140" stroke="#34d399" stroke-width="1.5" class="conn-line" />
              <circle cx="120" cy="50" r="20" fill="rgba(52,211,153,0.2)" stroke="#34d399" stroke-width="2" />
              <text x="120" y="46" text-anchor="middle" fill="#6ee7b7" font-size="7" font-weight="700">Connected</text>
              <text x="120" y="56" text-anchor="middle" fill="#6ee7b7" font-size="7" font-weight="700">Knowledge</text>
              <circle cx="40" cy="25" r="14" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1" />
              <text x="40" y="29" text-anchor="middle" fill="#6ee7b7" font-size="7">ESL</text>
              <circle cx="200" cy="25" r="14" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1" />
              <text x="200" y="29" text-anchor="middle" fill="#6ee7b7" font-size="7">Camera</text>
              <circle cx="40" cy="120" r="14" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1" />
              <text x="40" y="124" text-anchor="middle" fill="#6ee7b7" font-size="7">EPD</text>
              <circle cx="200" cy="120" r="14" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1" />
              <text x="200" y="124" text-anchor="middle" fill="#6ee7b7" font-size="7">Shelf</text>
              <circle cx="120" cy="140" r="14" fill="rgba(52,211,153,0.1)" stroke="#34d399" stroke-width="1" />
              <text x="120" y="144" text-anchor="middle" fill="#6ee7b7" font-size="7">S-Ward</text>
            </svg>
          </div>
        </div>
      </div>

      <!-- Structural limits table -->
      <div class="glass p-6 rounded-2xl mb-8 fade-in">
        <h3 class="text-sm font-bold text-white mb-4 text-center">구조적 한계</h3>
        <div class="grid md:grid-cols-3 gap-4">
          <div class="p-4 rounded-xl bg-red-950/20 border border-red-900/30 text-center">
            <div class="text-red-400 font-bold text-sm mb-2">시스템 단위 분리</div>
